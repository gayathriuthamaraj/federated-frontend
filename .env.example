# Copy this file to .env.local and adjust values for your setup.
# When running via Docker (setup-federation.bat / setup-federation.sh),
# the default value of http://localhost:8080 (Server A) is used automatically —
# you only need this file if you want to override that default.

# Backend identity server URL.
# Docker default: http://localhost:8080  (Server A)
# Switch to http://localhost:9080 if you want the frontend to talk to Server B.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
