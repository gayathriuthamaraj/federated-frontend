# Copy this file to .env.local and fill in values for your environment.
# The moderator panel runs as a single instance pointing at one backend.

# ── Production (Render) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_BACKEND_URL=https://fedinet-server-a.onrender.com
# NEXT_PUBLIC_MODERATION_URL=https://fedinet-server-a.onrender.com

# ── Local development ────────────────────────────────────────────────────────
# Identity server (handles moderator auth).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Go moderation service (cmd/moderation, port 8090).
NEXT_PUBLIC_MODERATION_URL=http://localhost:8090
